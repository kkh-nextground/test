{
  "name": "@nextground/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Nextground 디자인 시스템 — 아이콘/컴포넌트",
  "sideEffects": false,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkh-nextground/test.git"
  },
  "files": [
    "dist/icons"
  ],
  "exports": {
    "./icons/*": {
      "types": "./dist/icons/*/index.d.ts",
      "import": "./dist/icons/*/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "icons:build": "svgr --out-dir src/icons icons",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/react-vite": "^10.4.1",
    "@svgr/cli": "^8.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^10.4.1",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
